---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import Icon from "./Icon.astro";

interface Props {
  project: CollectionEntry<"projects">;
  variant?: "default" | "featured";
}

const { project, variant = "default" } = Astro.props;
const { title, description, kind, venue, date, link, image } = project.data;

const kindLabel =
  kind === "publication" ? "Publication" : kind === "dataset" ? "Dataset" : "Competition";
const formattedDate = date.toLocaleDateString("en-US", { year: "numeric", month: "long" });
const href = link ?? `/projects/${project.id}/`;
---

{
  variant === "featured" ? (
    <article class="grid grid-cols-1 gap-6 rounded-[var(--radius-md)] border border-border bg-surface p-6 lg:grid-cols-[160px_1fr]">
      <div class="flex size-full items-start">
        <span class="inline-grid size-16 place-items-center rounded-[var(--radius)] bg-accent/15 text-accent">
          <Icon name={kind === "publication" ? "scholar" : kind === "dataset" ? "tag" : "heart"} size={24} />
        </span>
      </div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-[1fr_auto]">
        <div class="space-y-5">
          <div class="flex flex-wrap items-center gap-2 text-xs text-muted">
            <span class="rounded-[var(--radius-pill)] border border-border bg-bg px-3 py-1 uppercase tracking-[0.08em]">{kindLabel}</span>
            <span>· {formattedDate}</span>
            {venue && <span>· {venue}</span>}
          </div>
          <a href={href} {...(link ? { target: "_blank", rel: "noopener" } : {})} class="block">
            <h3 class="font-display text-2xl font-semibold leading-tight tracking-tight text-ink transition-colors hover:text-accent md:text-3xl">
              {title}
            </h3>
          </a>
          <p class="text-base text-body">{description}</p>
        </div>
        <div class="flex items-end md:justify-end">
          <a
            href={href}
            {...(link ? { target: "_blank", rel: "noopener" } : {})}
            class="inline-flex items-center gap-2 rounded-[var(--radius)] border border-border bg-bg px-5 py-3 text-sm text-body transition-colors hover:border-border-subtle hover:text-ink"
          >
            {link ? "Visit" : "Details"}
            <Icon name="arrow-up-right" size={16} />
          </a>
        </div>
      </div>
    </article>
  ) : (
    <article class="group flex flex-col gap-5 rounded-[var(--radius-md)] border border-border bg-surface p-5 transition-colors hover:border-border-subtle">
      <div class="aspect-[16/10] overflow-hidden rounded-[var(--radius)]">
        {image ? (
          <Image
            src={image}
            alt={title}
            widths={[320, 640, 960]}
            sizes="(min-width: 1024px) 33vw, 100vw"
            class="size-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
          />
        ) : (
          <div class="size-full bg-gradient-to-br from-accent/20 via-surface-2 to-bg" />
        )}
      </div>
      <div class="space-y-3">
        <div class="flex flex-wrap items-center gap-2 text-xs text-muted">
          <span class="rounded-[var(--radius-pill)] border border-border bg-bg px-3 py-1 uppercase tracking-[0.08em]">{kindLabel}</span>
          <span>· {formattedDate}</span>
        </div>
        <a href={href} {...(link ? { target: "_blank", rel: "noopener" } : {})} class="block">
          <h3 class="font-display text-lg font-semibold leading-snug tracking-tight text-ink transition-colors group-hover:text-accent">
            {title}
          </h3>
        </a>
        <p class="line-clamp-3 text-sm text-body">{description}</p>
      </div>
      <a
        href={href}
        {...(link ? { target: "_blank", rel: "noopener" } : {})}
        class="mt-auto inline-flex items-center gap-2 self-start rounded-[var(--radius)] border border-border bg-bg px-4 py-2.5 text-sm text-body transition-colors group-hover:border-border-subtle group-hover:text-ink"
      >
        {link ? "Visit" : "Details"}
        <Icon name="arrow-up-right" size={14} />
      </a>
    </article>
  )
}
