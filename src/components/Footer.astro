---
import Container from "./Container.astro";
import Icon from "./Icon.astro";
import Logo from "./Logo.astro";

const year = new Date().getFullYear();

const columns = [
  {
    label: "Site",
    links: [
      { label: "Home", href: "/" },
      { label: "All Posts", href: "/posts" },
      { label: "Projects", href: "/projects" },
      { label: "About", href: "/about" },
      { label: "Contact", href: "/contact" },
    ],
  },
  {
    label: "Tracks",
    links: [
      { label: "For Engineers", href: "/posts/engineers" },
      { label: "For Everyone", href: "/posts/everyone" },
    ],
  },
  {
    label: "Follow",
    links: [
      { label: "GitHub", href: "https://github.com/remg1997", external: true },
      { label: "LinkedIn", href: "https://linkedin.com/in/rafael-mosquera", external: true },
      { label: "Scholar", href: "https://scholar.google.com/citations?user=XC9DJhUAAAAJ&hl", external: true },
      { label: "RSS", href: "/rss.xml" },
    ],
  },
];
---

<footer class="border-t border-border bg-surface">
  <Container as="div" class="flex flex-col gap-14 py-16 md:flex-row md:justify-between md:gap-16">
    <div class="max-w-sm space-y-4">
      <a href="/" class="inline-flex items-center gap-3 text-ink">
        <Logo height={36} />
        <span class="font-display text-base font-semibold tracking-tight">The Artificial Engineer</span>
      </a>
      <p class="text-sm text-muted">
        Practical ML engineering notes. Two tracks: deep dives for engineers and clear explainers for everyone.
      </p>
      <div class="flex items-center gap-3 text-muted">
        <a
          href="https://github.com/remg1997"
          aria-label="GitHub"
          class="grid size-10 place-items-center rounded-[var(--radius)] border border-border bg-bg transition-colors hover:border-border-subtle hover:text-ink"
          target="_blank"
          rel="noopener"
        >
          <Icon name="github" size={18} />
        </a>
        <a
          href="https://linkedin.com/in/rafael-mosquera"
          aria-label="LinkedIn"
          class="grid size-10 place-items-center rounded-[var(--radius)] border border-border bg-bg transition-colors hover:border-border-subtle hover:text-ink"
          target="_blank"
          rel="noopener"
        >
          <Icon name="linkedin" size={18} />
        </a>
        <a
          href="/rss.xml"
          aria-label="RSS feed"
          class="grid size-10 place-items-center rounded-[var(--radius)] border border-border bg-bg transition-colors hover:border-border-subtle hover:text-ink"
        >
          <Icon name="rss" size={18} />
        </a>
        <a
          href="mailto:rafael@theartificialengineer.ai"
          aria-label="Email"
          class="grid size-10 place-items-center rounded-[var(--radius)] border border-border bg-bg transition-colors hover:border-border-subtle hover:text-ink"
        >
          <Icon name="mail" size={18} />
        </a>
      </div>
    </div>

    <div class="grid flex-1 grid-cols-2 gap-10 md:max-w-xl md:grid-cols-3">
      {
        columns.map((col) => (
          <div class="space-y-5">
            <p class="font-display text-base font-medium text-ink">{col.label}</p>
            <ul class="space-y-3 text-sm">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-dim transition-colors hover:text-ink"
                    target={"external" in link && link.external ? "_blank" : undefined}
                    rel={"external" in link && link.external ? "noopener" : undefined}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </Container>

  <div class="border-t border-border">
    <Container as="div" class="flex flex-col items-center justify-between gap-3 py-6 text-xs text-dim md:flex-row">
      <p>© {year} The Artificial Engineer. All rights reserved.</p>
      <p>A two-track ML publication.</p>
    </Container>
  </div>
</footer>
