---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import Icon from "../components/Icon.astro";

const channels = [
  {
    label: "Email",
    items: [
      { value: "rafael@theartificialengineer.ai", href: "mailto:rafael@theartificialengineer.ai" },
    ],
  },
  {
    label: "Online",
    items: [
      { value: "github.com/remg1997", href: "https://github.com/remg1997" },
      { value: "linkedin.com/in/rafael-mosquera", href: "https://linkedin.com/in/rafael-mosquera" },
      { value: "Google Scholar", href: "https://scholar.google.com/citations?user=XC9DJhUAAAAJ&hl" },
    ],
  },
  {
    label: "Location",
    items: [{ value: "Bogotá, Colombia", href: null }],
  },
];

const faqs = [
  {
    q: "Will you collaborate on a paper or project?",
    a: "Maybe. I read every inbound email; if your project overlaps with ML evaluation, datasets, production inference, or alignment, there's a good chance I'll say yes. Include a short summary and what you'd want from me.",
  },
  {
    q: "Can you review my resume / refer me?",
    a: "I try, but bandwidth is limited. I'll always read a short email and reply with pointers; I won't do a live resume review unless there's a specific reason our paths should cross.",
  },
  {
    q: "Do you take on consulting?",
    a: "Occasionally, for ML evaluation, data pipelines, or small LLM inference work. Send a one-paragraph scope and I'll let you know.",
  },
  {
    q: "Will you speak at my event?",
    a: "Sometimes. Topics I'll talk about: evaluation, reproducibility, the research/production gap, datasets. Send date, format, and audience.",
  },
];
---

<BaseLayout
  title="Contact"
  description="Get in touch for collaborations, feedback on a post, or a question not yet covered."
>
  <section class="border-b border-border">
    <Container as="div" class="grid grid-cols-1 gap-10 py-20 md:grid-cols-4">
      {
        channels.map((c) => (
          <div class="space-y-4">
            <p class="font-display text-base font-medium text-ink">{c.label}</p>
            <ul class="space-y-3">
              {c.items.map((item) =>
                item.href ? (
                  <li>
                    <a
                      href={item.href}
                      target={item.href.startsWith("http") ? "_blank" : undefined}
                      rel={item.href.startsWith("http") ? "noopener" : undefined}
                      class="inline-flex items-center gap-2 rounded-[var(--radius)] border border-border bg-surface px-4 py-3 text-sm text-body transition-colors hover:border-border-subtle hover:text-ink"
                    >
                      {item.value}
                      <Icon name="arrow-up-right" size={14} />
                    </a>
                  </li>
                ) : (
                  <li class="text-sm text-body">{item.value}</li>
                ),
              )}
            </ul>
          </div>
        ))
      }
    </Container>
  </section>

  <section class="border-b border-border">
    <Container as="div" class="grid grid-cols-1 gap-12 py-20 lg:grid-cols-[minmax(0,_1fr)_minmax(0,_1.2fr)] lg:gap-20 lg:py-24">
      <div class="space-y-8">
        <div class="grid size-20 place-items-center rounded-[var(--radius-md)] bg-accent/15 text-accent">
          <Icon name="mail" size={28} />
        </div>
        <h2 class="font-display text-4xl font-semibold leading-tight tracking-[-0.02em] text-ink md:text-5xl lg:text-[58px] lg:leading-[1.1]">
          Say hi.
        </h2>
        <p class="max-w-md text-lg text-body">
          The quickest way to reach me is email. I don't always reply fast, but I do read every message.
        </p>
      </div>

      <form
        class="space-y-8 rounded-[var(--radius-md)] border border-border bg-surface p-8 md:p-10"
        action="https://formspree.io/f/your-form-id"
        method="POST"
        aria-label="Contact form"
      >
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
          <label class="space-y-2">
            <span class="block text-sm font-medium text-ink">First name</span>
            <input
              type="text"
              name="firstName"
              required
              class="w-full rounded-[var(--radius)] border border-border bg-bg px-5 py-4 text-base text-ink placeholder:text-dim focus:border-accent/60 focus:outline-none"
              placeholder="Your first name"
            />
          </label>
          <label class="space-y-2">
            <span class="block text-sm font-medium text-ink">Last name</span>
            <input
              type="text"
              name="lastName"
              class="w-full rounded-[var(--radius)] border border-border bg-bg px-5 py-4 text-base text-ink placeholder:text-dim focus:border-accent/60 focus:outline-none"
              placeholder="Your last name"
            />
          </label>
          <label class="space-y-2 md:col-span-2">
            <span class="block text-sm font-medium text-ink">Email</span>
            <input
              type="email"
              name="email"
              required
              class="w-full rounded-[var(--radius)] border border-border bg-bg px-5 py-4 text-base text-ink placeholder:text-dim focus:border-accent/60 focus:outline-none"
              placeholder="you@example.com"
            />
          </label>
          <label class="space-y-2 md:col-span-2">
            <span class="block text-sm font-medium text-ink">Message</span>
            <textarea
              name="message"
              required
              rows="6"
              class="w-full resize-none rounded-[var(--radius)] border border-border bg-bg px-5 py-4 text-base text-ink placeholder:text-dim focus:border-accent/60 focus:outline-none"
              placeholder="What would you like to talk about?"
            ></textarea>
          </label>
        </div>

        <div class="flex flex-col-reverse items-start gap-4 sm:flex-row sm:items-center sm:justify-between">
          <label class="flex items-start gap-3 text-sm text-body">
            <input type="checkbox" name="agree" required class="mt-1 size-4 rounded border-border bg-bg text-accent focus:ring-accent" />
            <span>I'm fine with the message being read and replied to.</span>
          </label>
          <button
            type="submit"
            class="inline-flex items-center gap-2 rounded-[var(--radius)] bg-accent px-8 py-4 text-sm font-medium text-accent-ink transition-opacity hover:opacity-90"
          >
            Send
            <Icon name="arrow-up-right" size={16} strokeWidth={2.25} />
          </button>
        </div>
      </form>
    </Container>
  </section>

  <section class="border-b border-border">
    <Container as="div" class="grid grid-cols-1 gap-12 py-20 lg:grid-cols-[minmax(0,_1fr)_minmax(0,_1.2fr)] lg:gap-20 lg:py-24">
      <div class="space-y-8">
        <div class="grid size-20 place-items-center rounded-[var(--radius-md)] bg-accent/15 text-accent">
          <Icon name="message" size={28} />
        </div>
        <h2 class="font-display text-4xl font-semibold leading-tight tracking-[-0.02em] text-ink md:text-5xl">
          Questions I often get.
        </h2>
        <p class="max-w-md text-base text-body">
          If your question isn't here, feel free to send it over. I'll add common ones as they come up.
        </p>
      </div>

      <div class="space-y-4">
        {
          faqs.map((item, idx) => (
            <details class="group rounded-[var(--radius-md)] border border-border bg-surface p-8 transition-colors open:border-border-subtle" open={idx === 0}>
              <summary class="flex cursor-pointer list-none items-center justify-between gap-6 text-ink">
                <span class="font-display text-lg font-medium leading-snug">{item.q}</span>
                <span class="grid size-8 place-items-center rounded-full border border-border bg-bg text-muted transition-colors group-open:rotate-180 group-open:text-ink">
                  <Icon name="chevron-down" size={16} />
                </span>
              </summary>
              <p class="mt-5 border-t border-border pt-5 text-base text-body">{item.a}</p>
            </details>
          ))
        }
      </div>
    </Container>
  </section>
</BaseLayout>
