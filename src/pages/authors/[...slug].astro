---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import Icon from "../../components/Icon.astro";
import PostCard from "../../components/PostCard.astro";

export async function getStaticPaths() {
  const authors = await getCollection("authors");
  return authors.map((author) => ({
    params: { slug: author.id },
    props: { author },
  }));
}

const { author } = Astro.props;
const { Content } = await render(author);
const { name, role, tagline, avatar, links } = author.data;

const allPosts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const authored = allPosts.filter((p) => p.data.author === author.id);

const iconLinks = [
  { key: "website", icon: "arrow-up-right" as const, label: "Website" },
  { key: "github", icon: "github" as const, label: "GitHub" },
  { key: "linkedin", icon: "linkedin" as const, label: "LinkedIn" },
  { key: "scholar", icon: "scholar" as const, label: "Google Scholar" },
  { key: "twitter", icon: "twitter" as const, label: "Twitter" },
  { key: "email", icon: "mail" as const, label: "Email", transform: (v: string) => `mailto:${v}` },
] as const;

const linkList = iconLinks
  .map((l) => {
    const value = links[l.key as keyof typeof links];
    if (!value) return null;
    const href = "transform" in l && l.transform ? l.transform(value) : value;
    return { href, icon: l.icon, label: l.label, external: href.startsWith("http") };
  })
  .filter((l): l is NonNullable<typeof l> => l !== null);

const initials = name
  .split(/\s+/)
  .map((w) => w[0])
  .slice(0, 2)
  .join("")
  .toUpperCase();
---

<BaseLayout
  title={name}
  description={tagline ?? `${name}, ${role} at The Artificial Engineer.`}
  hideCTA
>
  <section class="border-b border-border">
    <Container as="div" class="grid grid-cols-1 gap-10 py-20 lg:grid-cols-[auto_1fr] lg:gap-16 lg:py-28">
      {
        avatar ? (
          <Image
            src={avatar}
            alt={name}
            width={224}
            height={224}
            class="size-40 shrink-0 rounded-full object-cover md:size-56"
          />
        ) : (
          <span
            class="grid size-40 shrink-0 place-items-center rounded-full bg-accent/15 font-display text-5xl font-semibold text-accent md:size-56 md:text-6xl"
            aria-hidden="true"
          >
            {initials}
          </span>
        )
      }

      <div class="flex flex-col gap-6">
        <p class="text-sm font-medium uppercase tracking-[0.08em] text-muted">{role}</p>
        <h1 class="font-display text-4xl font-medium leading-[1.05] tracking-[-0.02em] text-ink md:text-6xl">
          {name}
        </h1>
        {tagline && <p class="max-w-2xl text-lg text-body md:text-xl">{tagline}</p>}

        {
          linkList.length > 0 && (
            <div class="flex flex-wrap items-center gap-2 pt-2 text-muted">
              {linkList.map((l) => (
                <a
                  href={l.href}
                  aria-label={l.label}
                  target={l.external ? "_blank" : undefined}
                  rel={l.external ? "noopener" : undefined}
                  class="grid size-10 place-items-center rounded-[var(--radius)] border border-border bg-surface transition-colors hover:border-border-subtle hover:text-ink"
                >
                  <Icon name={l.icon} size={18} />
                </a>
              ))}
            </div>
          )
        }
      </div>
    </Container>
  </section>

  <section class="border-b border-border">
    <Container as="div" class="grid grid-cols-1 gap-12 py-20 lg:grid-cols-[1fr_320px] lg:gap-20">
      <article class="prose prose-invert max-w-none">
        <Content />
      </article>
      <aside class="lg:sticky lg:top-28 lg:self-start">
        <div class="space-y-4 rounded-[var(--radius-md)] border border-border bg-surface p-6">
          <p class="text-xs uppercase tracking-[0.08em] text-muted">On this site</p>
          <p class="text-sm text-body">
            {authored.length === 0
              ? "No posts yet."
              : authored.length === 1
                ? "1 post published."
                : `${authored.length} posts published.`}
          </p>
          <a
            href="/posts"
            class="inline-flex items-center gap-1.5 text-sm text-body transition-colors hover:text-ink"
          >
            Browse all posts
            <Icon name="chevron-right" size={14} />
          </a>
        </div>
      </aside>
    </Container>
  </section>

  {
    authored.length > 0 && (
      <section>
        <Container as="div" class="flex flex-col gap-10 py-20">
          <h2 class="font-display text-3xl font-medium leading-tight tracking-tight text-ink md:text-4xl">
            Posts by {name}
          </h2>
          <div class="grid grid-cols-1 gap-10 md:grid-cols-3">
            {authored.slice(0, 6).map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        </Container>
      </section>
    )
  }
</BaseLayout>
