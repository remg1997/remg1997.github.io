---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import Icon from "../components/Icon.astro";
import PostCard from "../components/PostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const allPosts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const featured = allPosts[0];
const recent = allPosts.slice(1, 4);

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const featuredProjects = projects
  .filter((p) => p.data.featured)
  .concat(projects.filter((p) => !p.data.featured))
  .slice(0, 3);
---

<BaseLayout
  title="The Artificial Engineer"
  description="Writing at the seam between research and production. Deep dives for engineers and clear explainers for everyone."
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-border">
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-accent/5 via-bg to-bg" aria-hidden="true"></div>
    <Container as="div" class="relative flex flex-col items-start gap-10 py-24 lg:py-32">
      <span class="inline-flex items-center gap-2 rounded-[var(--radius-pill)] border border-border bg-surface px-4 py-2 text-sm text-body">
        <span class="size-1.5 rounded-full bg-accent"></span>
        ML engineering, without the hype
      </span>
      <h1 class="max-w-4xl font-display text-4xl font-medium leading-[1.05] tracking-[-0.02em] text-ink md:text-6xl lg:text-[72px]">
        Notes from the space where research papers become production systems.
      </h1>
      <p class="max-w-2xl text-lg text-body md:text-xl">
        I'm Rafael — a self-made ML engineer with a background in economics and law, four years of industry experience, and a NeurIPS best paper. This is where I share what I learn: deep technical dives for engineers, and clear explainers for everyone.
      </p>
      <div class="flex flex-wrap items-center gap-3">
        <a
          href="/posts"
          class="inline-flex items-center gap-2 rounded-[var(--radius)] bg-accent px-6 py-3.5 text-sm font-medium text-accent-ink transition-opacity hover:opacity-90"
        >
          Read the blog
          <Icon name="arrow-up-right" size={16} strokeWidth={2.25} />
        </a>
        <a
          href="/about"
          class="inline-flex items-center gap-2 rounded-[var(--radius)] border border-border bg-surface px-6 py-3.5 text-sm text-body transition-colors hover:border-border-subtle hover:text-ink"
        >
          About me
          <Icon name="chevron-right" size={16} />
        </a>
      </div>
    </Container>
  </section>

  <!-- Featured + recent posts -->
  {
    featured && (
      <section class="border-b border-border">
        <Container as="div" class="flex flex-col gap-12 py-20 lg:py-28">
          <div class="flex flex-wrap items-end justify-between gap-6">
            <div class="max-w-xl space-y-3">
              <p class="text-sm font-medium uppercase tracking-[0.08em] text-muted">Latest writing</p>
              <h2 class="font-display text-3xl font-medium leading-tight tracking-tight text-ink md:text-4xl">
                Fresh off the keyboard.
              </h2>
            </div>
            <a
              href="/posts"
              class="inline-flex items-center gap-2 rounded-[var(--radius)] border border-border bg-surface px-5 py-3 text-sm text-body transition-colors hover:border-border-subtle hover:text-ink"
            >
              All posts
              <Icon name="arrow-up-right" size={16} />
            </a>
          </div>

          <PostCard post={featured} variant="featured" />

          {recent.length > 0 && (
            <div class="grid grid-cols-1 gap-10 border-t border-border pt-12 md:grid-cols-3">
              {recent.map((post) => (
                <PostCard post={post} />
              ))}
            </div>
          )}
        </Container>
      </section>
    )
  }

  <!-- Projects teaser -->
  {
    featuredProjects.length > 0 && (
      <section class="border-b border-border bg-surface/40">
        <Container as="div" class="flex flex-col gap-12 py-20 lg:py-28">
          <div class="flex flex-wrap items-end justify-between gap-6">
            <div class="max-w-xl space-y-3">
              <p class="text-sm font-medium uppercase tracking-[0.08em] text-muted">Selected work</p>
              <h2 class="font-display text-3xl font-medium leading-tight tracking-tight text-ink md:text-4xl">
                Research, datasets, and systems I've shipped.
              </h2>
            </div>
            <a
              href="/projects"
              class="inline-flex items-center gap-2 rounded-[var(--radius)] border border-border bg-bg px-5 py-3 text-sm text-body transition-colors hover:border-border-subtle hover:text-ink"
            >
              All projects
              <Icon name="arrow-up-right" size={16} />
            </a>
          </div>

          <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
            {featuredProjects.map((project) => <ProjectCard project={project} />)}
          </div>
        </Container>
      </section>
    )
  }
</BaseLayout>
