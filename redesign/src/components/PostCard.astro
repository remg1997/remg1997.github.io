---
import type { CollectionEntry } from "astro:content";
import Icon from "./Icon.astro";
import TrackBadge from "./TrackBadge.astro";
import { Image } from "astro:assets";

interface Props {
  post: CollectionEntry<"posts">;
  variant?: "default" | "featured" | "row";
}

const { post, variant = "default" } = Astro.props;
const { title, excerpt, date, track, category, readingTime, image } = post.data;
const href = `/posts/${post.id}/`;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

{
  variant === "featured" ? (
    <article class="flex flex-col gap-8 rounded-[var(--radius-md)] border border-border bg-surface p-8 md:flex-row md:items-stretch md:gap-10 md:p-10">
      <a
        href={href}
        class="block aspect-[16/10] w-full overflow-hidden rounded-[var(--radius)] md:aspect-auto md:w-1/2"
      >
        {image ? (
          <Image
            src={image}
            alt={title}
            widths={[640, 960, 1280]}
            sizes="(min-width: 768px) 50vw, 100vw"
            class="size-full object-cover transition-transform duration-500 hover:scale-[1.02]"
          />
        ) : (
          <div class="size-full bg-gradient-to-br from-accent/30 via-surface-2 to-bg" />
        )}
      </a>
      <div class="flex flex-1 flex-col justify-between gap-6">
        <div class="space-y-4">
          <div class="flex flex-wrap items-center gap-2 text-xs text-muted">
            <TrackBadge track={track} />
            {category && <span class="uppercase tracking-[0.08em]">· {category}</span>}
          </div>
          <a href={href} class="block">
            <h2 class="font-display text-3xl font-semibold leading-tight tracking-tight text-ink transition-colors hover:text-accent md:text-4xl">
              {title}
            </h2>
          </a>
          <p class="line-clamp-3 text-base text-body md:text-lg">{excerpt}</p>
        </div>
        <div class="flex items-center justify-between gap-4 border-t border-border pt-5">
          <div class="flex items-center gap-4 text-xs text-muted">
            <span class="inline-flex items-center gap-1.5">
              <Icon name="calendar" size={14} />
              {formattedDate}
            </span>
            {readingTime && (
              <span class="inline-flex items-center gap-1.5">
                <Icon name="clock" size={14} />
                {readingTime}
              </span>
            )}
          </div>
          <a
            href={href}
            class="inline-flex items-center gap-2 rounded-[var(--radius)] border border-border bg-bg px-5 py-3 text-sm text-body transition-colors hover:border-border-subtle hover:text-ink"
          >
            Read post
            <Icon name="arrow-up-right" size={16} />
          </a>
        </div>
      </div>
    </article>
  ) : variant === "row" ? (
    <article class="group grid grid-cols-[auto_1fr_auto] items-center gap-6 border-b border-border py-6 last:border-b-0">
      <span class="grid size-12 place-items-center rounded-full border border-border bg-surface text-muted">
        <Icon name="user" size={16} />
      </span>
      <div class="min-w-0 space-y-2">
        <div class="flex flex-wrap items-center gap-2 text-xs text-muted">
          <TrackBadge track={track} />
          <span>· {formattedDate}</span>
          {readingTime && <span>· {readingTime}</span>}
        </div>
        <a href={href} class="block">
          <h3 class="font-display text-xl font-semibold leading-snug tracking-tight text-ink transition-colors group-hover:text-accent">
            {title}
          </h3>
        </a>
        <p class="line-clamp-2 text-sm text-body">{excerpt}</p>
      </div>
      <a
        href={href}
        class="hidden items-center gap-2 rounded-[var(--radius)] border border-border bg-bg px-4 py-2.5 text-sm text-body transition-colors group-hover:border-border-subtle group-hover:text-ink md:inline-flex"
      >
        Read
        <Icon name="arrow-up-right" size={14} />
      </a>
    </article>
  ) : (
    <article class="group flex flex-col gap-5">
      <a href={href} class="block aspect-[16/10] overflow-hidden rounded-[var(--radius-md)]">
        {image ? (
          <Image
            src={image}
            alt={title}
            widths={[320, 640, 960]}
            sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
            class="size-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
          />
        ) : (
          <div class="size-full bg-gradient-to-br from-accent/25 via-surface-2 to-bg" />
        )}
      </a>
      <div class="space-y-3">
        <TrackBadge track={track} />
        <a href={href} class="block">
          <h3 class="font-display text-xl font-semibold leading-snug tracking-tight text-ink transition-colors group-hover:text-accent">
            {title}
          </h3>
        </a>
        <p class="line-clamp-2 text-sm text-body">{excerpt}</p>
        <div class="flex items-center gap-3 text-xs text-muted">
          <span class="inline-flex items-center gap-1.5">
            <Icon name="calendar" size={14} />
            {formattedDate}
          </span>
          {readingTime && (
            <span class="inline-flex items-center gap-1.5">
              <Icon name="clock" size={14} />
              {readingTime}
            </span>
          )}
        </div>
      </div>
    </article>
  )
}
