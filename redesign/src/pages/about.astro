---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import Icon from "../components/Icon.astro";

const pillars = [
  {
    label: "Background",
    body: "Economics and law by degree; ML engineer by practice. Four years of industry experience building datasets, evaluation systems, and production inference.",
  },
  {
    label: "Recognition",
    body: "NeurIPS D&B 2024 best paper (Prism Alignment Dataset). Contributions to Dynabench, People's Speech, Adversarial Nibbler, DataPerf, BabyLM.",
  },
  {
    label: "Focus",
    body: "Reproducible evaluation, honest assessments of what works in production, and the gap between research papers and shipped systems.",
  },
];
---

<BaseLayout
  title="About"
  description="About Rafael Mosquera — self-made ML engineer, economics and law background, NeurIPS best paper, writing at the seam of research and production."
>
  <section class="border-b border-border">
    <Container as="div" class="flex flex-col gap-10 py-20 lg:py-28">
      <p class="text-sm font-medium uppercase tracking-[0.08em] text-muted">About</p>
      <h1 class="max-w-4xl font-display text-4xl font-medium leading-[1.05] tracking-[-0.02em] text-ink md:text-6xl lg:text-[72px]">
        I make artificial-intelligence systems work in the real world.
      </h1>
      <p class="max-w-3xl text-lg text-body md:text-xl">
        I'm Rafael Mosquera. I came to ML the long way round — through economics and law, then four years of industry debugging, dataset building, and production inference. This site is where I work out loud: what I'm learning, what's not in the tutorials, and what the gap between a published paper and a shipped system really feels like.
      </p>
    </Container>
  </section>

  <section class="border-b border-border">
    <Container as="div" class="grid grid-cols-1 gap-6 py-16 md:grid-cols-3">
      {
        pillars.map((p) => (
          <div class="space-y-5 rounded-[var(--radius-md)] border border-border bg-surface p-8">
            <p class="text-sm font-medium uppercase tracking-[0.08em] text-muted">{p.label}</p>
            <p class="text-base text-body">{p.body}</p>
          </div>
        ))
      }
    </Container>
  </section>

  <section class="border-b border-border">
    <Container as="div" class="grid grid-cols-1 gap-12 py-20 lg:grid-cols-[minmax(0,_1fr)_minmax(0,_1.5fr)] lg:gap-20">
      <div class="space-y-6">
        <p class="text-sm font-medium uppercase tracking-[0.08em] text-muted">The premise</p>
        <h2 class="font-display text-3xl font-medium leading-tight tracking-tight text-ink md:text-4xl">
          Two tracks, one mission.
        </h2>
      </div>
      <div class="space-y-8 text-base text-body md:text-lg">
        <p>
          After one too many 2 AM debugging sessions, I noticed a consistent pattern: the gap between research papers and production reality is bigger than anyone admits. Technical writing often assumes you've been in the bubble. Popular ML writing flattens nuance until it's misleading. There are very few bridges between the two.
        </p>
        <p>
          That's the shape this blog takes. Two parallel tracks, each closing the gap from a different side:
        </p>
        <div class="grid grid-cols-1 gap-5 pt-2 md:grid-cols-2">
          <div class="space-y-3 rounded-[var(--radius-md)] border border-border bg-surface p-6">
            <p class="font-display text-xl font-semibold text-ink">For Engineers</p>
            <p class="text-base text-body">
              Reproducible experiments, benchmarks, architecture breakdowns, and the production lessons I learned the hard way.
            </p>
          </div>
          <div class="space-y-3 rounded-[var(--radius-md)] border border-border bg-surface p-6">
            <p class="font-display text-xl font-semibold text-ink">For Everyone</p>
            <p class="text-base text-body">
              Plain-English explainers of how AI shapes daily life, with analogies that stick and no PhD required.
            </p>
          </div>
        </div>
        <p>
          I'm not a "real" engineer by degree, but I've spent four years making AI systems work in the real world. The name captures the irony: someone artificial (by training) engineering artificial intelligence.
        </p>
      </div>
    </Container>
  </section>

  <section class="border-b border-border">
    <Container as="div" class="flex flex-col items-start gap-8 py-16">
      <h2 class="max-w-3xl font-display text-3xl font-medium leading-tight tracking-tight text-ink md:text-4xl">
        Say hello.
      </h2>
      <p class="max-w-2xl text-base text-body md:text-lg">
        If you have a specific engineering challenge, a post idea, or just want to argue about evaluation methodology — I'd love to hear from you.
      </p>
      <div class="flex flex-wrap items-center gap-3">
        <a
          href="/contact"
          class="inline-flex items-center gap-2 rounded-[var(--radius)] bg-accent px-6 py-3.5 text-sm font-medium text-accent-ink transition-opacity hover:opacity-90"
        >
          Get in touch
          <Icon name="arrow-up-right" size={16} strokeWidth={2.25} />
        </a>
        <a
          href="mailto:rafael@theartificialengineer.ai"
          class="inline-flex items-center gap-2 rounded-[var(--radius)] border border-border bg-surface px-6 py-3.5 text-sm text-body transition-colors hover:border-border-subtle hover:text-ink"
        >
          rafael@theartificialengineer.ai
          <Icon name="mail" size={16} />
        </a>
      </div>
    </Container>
  </section>
</BaseLayout>
