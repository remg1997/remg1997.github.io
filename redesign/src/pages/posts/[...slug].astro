---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import Icon from "../../components/Icon.astro";
import PostCard from "../../components/PostCard.astro";
import TrackBadge from "../../components/TrackBadge.astro";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(post);
const { title, excerpt, date, track, category, readingTime, image, author, tags } = post.data;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const computedReadingTime =
  readingTime ?? (remarkPluginFrontmatter?.minutesRead as string | undefined);

// Related posts: same track, excluding current, most recent first
const allPosts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const related = allPosts
  .filter((p) => p.id !== post.id && p.data.track === track)
  .slice(0, 3);

const fallbackRelated = related.length === 0 ? allPosts.filter((p) => p.id !== post.id).slice(0, 3) : related;

// Build Table of Contents from h2/h3 headings
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<BaseLayout title={title} description={excerpt} image={image ? undefined : "/og-default.png"}>
  <!-- Hero -->
  <section class="relative border-b border-border">
    <div class="relative h-[50vh] min-h-[420px] w-full overflow-hidden">
      {
        image ? (
          <Image
            src={image}
            alt={title}
            widths={[960, 1440, 1920]}
            sizes="100vw"
            class="size-full object-cover"
          />
        ) : (
          <div class="size-full bg-gradient-to-br from-accent/20 via-surface-2 to-bg" />
        )
      }
      <div class="absolute inset-0 bg-gradient-to-b from-bg/40 via-bg/70 to-bg"></div>
      <Container as="div" class="relative flex h-full flex-col justify-end pb-12 lg:pb-16">
        <div class="space-y-5">
          <div class="flex flex-wrap items-center gap-2 text-xs text-muted">
            <TrackBadge track={track} />
            {category && <span class="uppercase tracking-[0.08em]">· {category}</span>}
          </div>
          <h1 class="max-w-4xl font-display text-4xl font-semibold leading-[1.1] tracking-[-0.02em] text-ink md:text-5xl lg:text-[64px]">
            {title}
          </h1>
        </div>
      </Container>
    </div>
  </section>

  <!-- Body + sidebar -->
  <section class="border-b border-border">
    <Container as="div" class="grid grid-cols-1 gap-16 py-16 lg:grid-cols-[1fr_320px] lg:gap-20 lg:py-20">
      <article class="min-w-0 space-y-10">
        <div class="space-y-4 border-b border-border pb-10">
          <p class="text-sm font-medium uppercase tracking-[0.08em] text-muted">Introduction</p>
          <p class="text-lg text-body md:text-xl">{excerpt}</p>
        </div>

        <div class="prose prose-invert max-w-none">
          <Content />
        </div>

        {
          tags.length > 0 && (
            <div class="flex flex-wrap items-center gap-2 border-t border-border pt-8">
              <span class="text-sm text-muted">Tagged</span>
              {tags.map((tag) => (
                <span class="rounded-[var(--radius-pill)] border border-border bg-surface px-3 py-1 text-xs text-body">
                  #{tag}
                </span>
              ))}
            </div>
          )
        }
      </article>

      <aside class="lg:sticky lg:top-28 lg:self-start">
        <div class="space-y-8 rounded-[var(--radius-md)] border border-border bg-surface p-8">
          <div class="grid grid-cols-2 gap-6">
            <div class="space-y-1">
              <p class="text-xs uppercase tracking-[0.08em] text-muted">Published</p>
              <p class="text-sm font-medium text-ink">{formattedDate}</p>
            </div>
            <div class="space-y-1">
              <p class="text-xs uppercase tracking-[0.08em] text-muted">Track</p>
              <p class="text-sm font-medium text-ink">{track === "engineers" ? "For Engineers" : "For Everyone"}</p>
            </div>
            {computedReadingTime && (
              <div class="space-y-1">
                <p class="text-xs uppercase tracking-[0.08em] text-muted">Reading time</p>
                <p class="text-sm font-medium text-ink">{computedReadingTime}</p>
              </div>
            )}
            <div class="space-y-1">
              <p class="text-xs uppercase tracking-[0.08em] text-muted">Author</p>
              <p class="text-sm font-medium text-ink">{author}</p>
            </div>
          </div>

          {
            toc.length > 0 && (
              <div class="space-y-4 border-t border-border pt-6">
                <p class="text-xs uppercase tracking-[0.08em] text-muted">Contents</p>
                <ol class="space-y-2 text-sm">
                  {toc.map((h) => (
                    <li class={h.depth === 3 ? "ml-4" : ""}>
                      <a href={`#${h.slug}`} class="text-body transition-colors hover:text-ink">
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ol>
              </div>
            )
          }
        </div>
      </aside>
    </Container>
  </section>

  <!-- Related posts -->
  {
    fallbackRelated.length > 0 && (
      <section>
        <Container as="div" class="flex flex-col gap-10 py-20">
          <div class="flex flex-wrap items-end justify-between gap-6">
            <h2 class="font-display text-3xl font-medium leading-tight tracking-tight text-ink md:text-4xl">
              Keep reading.
            </h2>
            <a
              href="/posts"
              class="inline-flex items-center gap-2 rounded-[var(--radius)] border border-border bg-surface px-5 py-3 text-sm text-body transition-colors hover:border-border-subtle hover:text-ink"
            >
              All posts
              <Icon name="arrow-up-right" size={16} />
            </a>
          </div>

          <div class="grid grid-cols-1 gap-10 md:grid-cols-3">
            {fallbackRelated.map((p) => <PostCard post={p} />)}
          </div>
        </Container>
      </section>
    )
  }
</BaseLayout>
